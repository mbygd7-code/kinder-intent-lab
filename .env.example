# Kinder Intent Lab — 환경 변수 (실키 커밋 금지, .env는 gitignore됨)
# Supabase 사용 시: 대시보드 Connect → Session pooler URI를 복사해 .env의 DATABASE_URL에 넣는다
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kinder_intent_lab

# --- LLM (completion) ---
# 기본은 오프라인 합성/mock. 실 Claude 연결 시 아래처럼 바꾼다 (실제 호출은 과금됨):
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=sk-ant-...
#   LLM_MODEL=claude-opus-4-8      # 완성 모델 (기본 claude-opus-4-8)
#   LLM_MAX_TOKENS=4096            # 응답 토큰 상한 (기본 4096)
# 설치: pip install 'kinder-intent-backend[anthropic]'
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=claude-opus-4-8
LLM_MAX_TOKENS=4096

# --- 임베딩 ---
# 별도 provider. DB는 vector(1536). 실 OpenAI 임베딩 예시 (text-embedding-3-small=1536):
#   EMBEDDING_PROVIDER=openai        # 소문자
#   EMBEDDING_API_KEY=sk-...         # 없으면 OPENAI_API_KEY로 폴백
#   EMBEDDING_MODEL=text-embedding-3-small
#   EMBEDDING_DIM=1536               # DB vector(1536)와 일치(create에 dimensions로 강제)
# 설치: pip install 'kinder-intent-backend[openai]'
EMBEDDING_PROVIDER=mock

# --- 배포(선택) ---
# 프론트·백엔드를 서로 다른 도메인에 올리고 Vercel rewrite(/v1 프록시)를 쓰지 않을 때만 필요.
# 허용할 프론트 출처를 쉼표로 나열(예: https://kinder.vercel.app). 비우면 CORS 비활성 —
# 동일출처·rewrite 배포에는 불필요하다. 전체 배포 절차는 docs/10-deploy/README.md.
CORS_ALLOW_ORIGINS=
