{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kinder://schemas/infer_response.schema.json",
  "title": "InferResponse",
  "type": "object",
  "required": ["request_id", "schema_version", "model_version", "ontology_version", "intent_candidates", "top_intent", "confidence", "margin", "is_multi_intent", "decision", "persona_state_version"],
  "properties": {
    "request_id": {"type": "string"},
    "schema_version": {"type": "string"},
    "model_version": {"type": "string"},
    "ontology_version": {"type": "string"},
    "latency_ms": {"type": "integer"},
    "intent_candidates": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["intent_id", "domain", "score", "risk_tier", "requires_confirmation"],
        "properties": {
          "intent_id": {"type": "string"},
          "domain": {"type": "string", "enum": ["PLAY", "OBSERVATION", "DOCUMENT", "VISUAL", "COMMUNICATION", "OPERATION", "REFLECTION"]},
          "score": {"type": "number", "minimum": 0, "maximum": 1},
          "risk_tier": {"type": "string", "enum": ["LOW", "MED", "HIGH", "CRITICAL"]},
          "requires_confirmation": {"type": "boolean"},
          "evidence": {"type": "array", "items": {"type": "object", "required": ["signal", "detail"], "properties": {"signal": {"type": "string"}, "detail": {"type": "string"}}}},
          "proposed_action": {
            "type": "object",
            "required": ["action_type"],
            "properties": {
              "action_type": {"type": "string"},
              "target_objects": {"type": "array", "items": {"type": "string"}},
              "params": {"type": "object"},
              "preview_available": {"type": "boolean"},
              "undoable": {"type": "boolean"}
            }
          }
        }
      }
    },
    "top_intent": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "margin": {"type": "number", "minimum": 0, "maximum": 1},
    "is_multi_intent": {"type": "boolean"},
    "intent_plan": {
      "type": ["object", "null"],
      "properties": {
        "intents": {"type": "array", "items": {"type": "string"}, "minItems": 2},
        "relation": {"type": "string", "enum": ["sequential", "parallel", "alternative"]},
        "execution_order": {"type": "array", "items": {"type": "string"}}
      },
      "required": ["intents", "relation"]
    },
    "decision": {"type": "string", "enum": ["execute", "suggest", "clarify", "abstain"]},
    "clarification": {
      "type": ["object", "null"],
      "properties": {
        "question": {"type": "string"},
        "options": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "object", "required": ["label", "intent_id"]}}
      }
    },
    "abstain_reason": {"type": ["string", "null"], "enum": ["LOW_CONFIDENCE", "OOD", "DEADLINE_RISK", null]},
    "compute_elapsed_ms": {"type": ["integer", "null"]},
    "remaining_budget_ms": {"type": ["integer", "null"]},
    "persona_state_version": {"type": "string"},
    "persona_snapshot_hash": {"type": "string"},
    "fallback_used": {"type": "boolean"}
  },
  "allOf": [
    {"if": {"properties": {"is_multi_intent": {"const": true}}}, "then": {"properties": {"intent_plan": {"type": "object"}}, "required": ["intent_plan"]}},
    {"if": {"properties": {"is_multi_intent": {"const": false}}}, "then": {"properties": {"intent_plan": {"type": "null"}}}}
  ]
}
